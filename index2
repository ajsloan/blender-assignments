          <div style="height:5px;background:linear-gradient(90deg,#f4a231,#e8921a);"></div>
          <!-- Card header -->
          <div style="padding:16px 18px 14px;">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
              <div style="background:#f4a23120;border:1px solid #f4a23150;color:#f4a231;font-size:10px;font-weight:bold;padding:3px 10px;border-radius:20px;letter-spacing:1px;">PROJECT 4.07</div>
              <div style="background:#27ae6020;border:1px solid #27ae6050;color:#27ae60;font-size:10px;font-weight:bold;padding:3px 10px;border-radius:20px;">✓ Available</div>
