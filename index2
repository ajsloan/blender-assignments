            <div style="font-size:17px;font-weight:bold;color:#fff;margin-bottom:4px;">What Will You Have to Drink?</div>
            <div style="font-size:12px;color:#8ab8c5;line-height:1.5;margin-bottom:14px;">Create a 3D pitcher with handle using Bezier curves, the Screw Modifier, and Extrude Along a Path.</div>
            <!-- Tags -->
            <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px;">
              <span style="background:#1a2535;color:#8ab8c5;font-size:10px;padding:3px 8px;border-radius:4px;">Bezier Curves</span>
              <span style="background:#1a2535;color:#8ab8c5;font-size:10px;padding:3px 8px;border-radius:4px;">Screw Modifier</span>
              <span style="background:#1a2535;color:#8ab8c5;font-size:10px;padding:3px 8px;border-radius:4px;">Bevel Object</span>
            </div>
            <!-- Footer -->
            <div style="display:flex;align-items:center;justify-content:space-between;padding-top:12px;border-top:1px solid #1e3040;">
              <div style="display:flex;gap:12px;">
                <span style="font-size:11px;color:#5a8a96;">🎯 40 pts</span>
                <span style="font-size:11px;color:#5a8a96;">📸 4 screenshots</span>
              </div>
              <div style="background:#f4a231;color:#0d3b47;font-size:11px;font-weight:bold;padding:5px 14px;border-radius:5px;">Open →</div>
            </div>
          </div>
        </div>
      </a>
    </div>

    <!-- 4.08 COMING SOON -->
    <div class="card">
      <div class="coming-soon">
        <div style="height:5px;background:#1a2535;"></div>
        <div style="padding:16px 18px 14px;">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
            <div style="background:#1a253520;border:1px solid #1e3040;color:#3a5060;font-size:10px;font-weight:bold;padding:3px 10px;border-radius:20px;letter-spacing:1px;">PROJECT 4.08</div>
