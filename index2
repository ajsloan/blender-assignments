          <div style="background:#0a0f1a;border-radius:8px;height:90px;margin-bottom:12px;display:flex;align-items:center;justify-content:center;">
            <span style="font-size:32px;opacity:.3;">🔒</span>
          </div>
          <div style="font-size:17px;font-weight:bold;color:#3a5060;margin-bottom:4px;">Assignment Coming Soon</div>
          <div style="font-size:12px;color:#2a4050;line-height:1.5;margin-bottom:14px;">This assignment will be available soon. Check back later!</div>
          <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px;">
            <span style="background:#0d1117;color:#1e3040;font-size:10px;padding:3px 8px;border-radius:4px;">TBA</span>
          </div>
          <div style="display:flex;align-items:center;justify-content:space-between;padding-top:12px;border-top:1px solid #111820;">
            <span style="font-size:11px;color:#2a4050;">Not yet available</span>
            <div style="background:#1a2535;color:#2a4050;font-size:11px;font-weight:bold;padding:5px 14px;border-radius:5px;">Locked</div>
          </div>
        </div>
      </div>
    </div>

    <!-- 4.09 COMING SOON -->
    <div class="card">
      <div class="coming-soon">
        <div style="height:5px;background:#1a2535;"></div>
        <div style="padding:16px 18px 14px;">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
            <div style="background:#1a253520;border:1px solid #1e3040;color:#3a5060;font-size:10px;font-weight:bold;padding:3px 10px;border-radius:20px;letter-spacing:1px;">PROJECT 4.09</div>
            <div style="background:#1a253520;border:1px solid #1e3040;color:#3a5060;font-size:10px;font-weight:bold;padding:3px 10px;border-radius:20px;">Coming Soon</div>
          </div>
          <div style="background:#0a0f1a;border-radius:8px;height:90px;margin-bottom:12px;display:flex;align-items:center;justify-content:center;">
            <span style="font-size:32px;opacity:.3;">🔒</span>
          </div>
          <div style="font-size:17px;font-weight:bold;color:#3a5060;margin-bottom:4px;">Assignment Coming Soon</div>
          <div style="font-size:12px;color:#2a4050;line-height:1.5;margin-bottom:14px;">This assignment will be available soon. Check back later!</div>
          <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px;">
            <span style="background:#0d1117;color:#1e3040;font-size:10px;padding:3px 8px;border-radius:4px;">TBA</span>
          </div>
          <div style="display:flex;align-items:center;justify-content:space-between;padding-top:12px;border-top:1px solid #111820;">
            <span style="font-size:11px;color:#2a4050;">Not yet available</span>
            <div style="background:#1a2535;color:#2a4050;font-size:11px;font-weight:bold;padding:5px 14px;border-radius:5px;">Locked</div>
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- AI Assistant callout -->
  <div style="background:#061a22;border:2px solid #f4a231;border-radius:12px;padding:20px 24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;">
    <div>
      <div style="font-size:16px;font-weight:bold;color:#fff;margin-bottom:4px;">🤖 Every assignment includes an AI Assistant</div>
      <div style="font-size:13px;color:#8ab8c5;">Stuck on a step? The AI knows every assignment and can answer any Blender question in plain language.</div>
    </div>
    <a href="./4-07-pitcher/" style="background:#f4a231;color:#0d3b47;font-size:13px;font-weight:bold;padding:12px 22px;border-radius:6px;text-decoration:none;white-space:nowrap;">Start Project 4.07 →</a>
  </div>

</div>
</body>
</html>
