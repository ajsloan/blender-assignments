                <path d="M30,82 Q28,65 30,48 Q32,30 40,22 Q46,18 52,18 Q58,18 64,22 Q72,30 74,48 Q76,65 74,82 Z" fill="#1a6b7c" fill-opacity=".5"/>
                <path d="M30,82 Q28,65 30,48 Q32,30 40,22" fill="none" stroke="#28a0b5" stroke-width="1.5"/>
                <path d="M74,82 Q76,65 74,48 Q72,30 64,22" fill="none" stroke="#28a0b5" stroke-width="1.5"/>
                <ellipse cx="52" cy="82" rx="22" ry="4" fill="#1a6b7c" stroke="#28a0b5" stroke-width="1.5"/>
                <ellipse cx="52" cy="18" rx="12" ry="3" fill="#1a6b7c" stroke="#28a0b5" stroke-width="1.5"/>
                <path d="M74,35 Q95,35 95,52 Q95,69 74,69" fill="none" stroke="#f4a231" stroke-width="7" stroke-linecap="round"/>
